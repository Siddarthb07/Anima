# Copy to .env.benchmark and edit paths, then:
#   Get-Content .env.benchmark | ForEach-Object { if ($_ -match '^([^#][^=]+)=(.*)$') { Set-Item -Path "env:$($matches[1].Trim())" -Value $matches[2].Trim() } }

# Guard benchmarks (defaults use repo fixtures)
TRUTHFULQA_PATH=benchmarks/fixtures/truthfulqa_guard_sample.json
HALUEVAL_PATH=benchmarks/fixtures/halueval_guard_sample.json

# Narratives fMRI (OpenNeuro ds002345) — required for narratives_holdout / anima train
# NARRATIVES_ROOT=C:\data\ds002345

# Optional: skip heavy / incompatible suites
SKIP_BRAINSCORE=1

# TRIBE: surrogate | runtime | blend
ANIMA_TRIBE_MODE=surrogate
