# Proxy target for Vite dev (/ws -> FastAPI). Must match uvicorn host:port.
VITE_API_HTTP_TARGET=http://127.0.0.1:8010

# Default HF model id in the UI (see core/layer_config.py).
VITE_DEFAULT_MODEL=hf-internal-testing/tiny-random-gpt2

# Optional: bypass dev proxy (remote API, etc.)
# VITE_WS_DIRECT=1
# VITE_WS_BASE=ws://127.0.0.1:8010
